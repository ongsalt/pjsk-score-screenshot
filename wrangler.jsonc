{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "pjsk-stuff",
  "compatibility_date": "2026-03-13",
  "compatibility_flags": [
    "nodejs_als"
  ],
  // "main": ".svelte-kit/cloudflare/_worker.js",
  "assets": {
    // "binding": "ASSETS",
    "directory": "build",
  },
  "build": {
    "watch_dir": "./src",
    "command": "bun run build"
  },
  "workers_dev": false,
  "route": {
    "pattern": "sekai.ongsa.lt",
    "custom_domain": true
  },
}